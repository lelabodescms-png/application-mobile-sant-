DATABASE_URL="postgresql://user:password@host:5432/database"

# Secret utilisé pour signer les cookies de session — générer une vraie
# valeur avant toute mise en ligne, ex : openssl rand -base64 32
AUTH_SECRET="change-me"

# URL publique de l'application (utilisée dans les SMS envoyés aux clients)
APP_URL="http://localhost:3000"

# Fournisseur SMS (Twilio). Laisser vide en développement : les SMS seront
# simplement affichés dans les logs du serveur au lieu d'être envoyés.
# Pas besoin de numéro de téléphone Twilio pour la France : le SMS est
# envoyé avec le nom de l'entreprise du couvreur comme expéditeur
# (Alphanumeric Sender ID), supporté sans inscription préalable.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# Optionnel : numéro Twilio classique utilisé comme expéditeur de secours
# quand le pays du destinataire refuse le Sender ID alphanumérique (ex :
# Maroc). Acheter un numéro US/UK sur Twilio (~1$/mois, aucun document
# requis) suffit — il n'a pas besoin d'être dans le même pays que les
# destinataires.
TWILIO_FALLBACK_FROM_NUMBER=""

# Stockage des photos (S3-compatible : Cloudflare R2, AWS S3, OVH Object
# Storage...). Laisser vide en développement : les photos sont alors
# stockées sur le disque local (public/uploads/), ce qui NE FONCTIONNE PAS
# sur un hébergeur serverless (Vercel) où le disque ne persiste pas.
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="auto"
S3_PUBLIC_URL_BASE=""
