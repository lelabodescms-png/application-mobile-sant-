# Copie ce fichier en .env et remplis tes propres valeurs.
# Ne commite JAMAIS le fichier .env (il est dans .gitignore).

# --- Telegram (voir README pour la procédure BotFather) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Ton email de contact, affiché dans le User-Agent des requêtes ---
CONTACT_EMAIL=ton-email@example.com

# --- Requête Gmail pour repérer les alertes job (syntaxe de recherche Gmail) ---
GMAIL_QUERY=from:(jobalerts-noreply@indeed.com OR alerte@indeed.com OR welcometothejungle.com) newer_than:2d

# --- Niveau de log : DEBUG, INFO, WARNING, ERROR ---
LOG_LEVEL=INFO
